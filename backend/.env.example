# StadiumIQ Environment Configuration
# Copy to .env and fill in your values

# ── GOOGLE GEMINI ─────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ── SERVER ────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
DEBUG=true
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ── LANGGRAPH ─────────────────────────────────────────
LANGGRAPH_CHECKPOINTER=sqlite
SQLITE_DB_PATH=./stadiumiq_memory.db

# ── A2A AGENT ENDPOINTS ───────────────────────────────
A2A_FAN_AGENT_URL=http://localhost:8000/a2a/fan
A2A_CROWD_AGENT_URL=http://localhost:8000/a2a/crowd
A2A_INCIDENT_AGENT_URL=http://localhost:8000/a2a/incident
A2A_TRANSPORT_AGENT_URL=http://localhost:8000/a2a/transport
A2A_ECO_AGENT_URL=http://localhost:8000/a2a/eco
A2A_OPS_AGENT_URL=http://localhost:8000/a2a/ops

# ── MCP SERVER PORTS ──────────────────────────────────
MCP_STADIUM_PORT=8010
MCP_CROWD_PORT=8011
MCP_TRANSPORT_PORT=8012
MCP_ECO_PORT=8013

# ── GRAPHRAG ──────────────────────────────────────────
GRAPHRAG_INDEX_PATH=./graph_rag/index
GRAPHRAG_EMBEDDING_MODEL=models/text-embedding-004

# ── RATE LIMITING ─────────────────────────────────────
RATE_LIMIT_PER_MINUTE=60
AI_RATE_LIMIT_PER_MINUTE=30

# ── LOGGING ───────────────────────────────────────────
LOG_LEVEL=INFO
LOG_FORMAT=json
